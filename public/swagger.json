      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "Get completed job result",
        "description": "Mengambil result JSON final. Untuk PATHWAY_GEN, field result mengikuti ClinicalPathwayOutput. Untuk CLAIM_VALIDATION, field result mengikuti ClaimValidationOutput.",
