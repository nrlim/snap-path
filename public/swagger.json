    "/api/v1/claims/map-json": {
      "post": {
        "tags": [
          "Claim Workflows"
        ],
        "summary": "Map arbitrary JSON to SnapPath claim schema",
        "description": "Mengubah payload dari SIMRS/FHIR/HL7/custom export menjadi struktur ClaimValidationInput. Endpoint ini menggunakan AI dan mengembalikan usage token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mapped claim payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "mapped": {
                      "$ref": "#/components/schemas/ClaimValidationInput"
                    },
                    "_mappingNotes": {
                      "type": "string"
                    },
                    "usage": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
